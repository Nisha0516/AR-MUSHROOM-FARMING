NODE_ENV=development
PORT=5000

# MongoDB Connection - Replace with your connection string
# For local MongoDB:
MONGODB_URI=mongodb://127.0.0.1:27017/mushroom_farm

# For MongoDB Atlas (Cloud) - Uncomment and replace with your connection string:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mushroom_farm?retryWrites=true&w=majority

# JWT Secret for authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
